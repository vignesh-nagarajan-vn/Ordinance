# Copy this file to .env.local for local development, and set the same variable
# in your Vercel project's Environment Variables for deployment.
#
# Server-only secret. Do NOT prefix with NEXT_PUBLIC_, that would expose the
# key to the browser. The /api routes read this server-side and proxy Anthropic,
# so the key never reaches the client.
ANTHROPIC_API_KEY=your-anthropic-api-key-here
